# ============================================
# GymCoach - Variables de Entorno
# ============================================
# Copia este archivo a .env.local y completa los valores

# Supabase (requerido)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Publishable key (sb_publishable_...) o legacy anon - para cliente y servidor con sesión
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-publishable-key
# Secret key (sb_secret_...) o legacy service_role - SOLO servidor (validación invitaciones, etc.). NUNCA exponer.
SUPABASE_SERVICE_ROLE_KEY=tu-secret-key

# Codigo de activacion para primer admin (requerido en produccion)
# IMPORTANTE: Usa un codigo unico y seguro. No exponer en cliente.
# Solo se valida en el servidor.
ADMIN_SETUP_CODE=GYMCOACH2026

# Resend - Correos transaccionales (opcional pero recomendado en produccion)
# Sin esto, los codigos de invitacion NO se envian por correo (solo se muestran en pantalla)
# Obtén tu API key en https://resend.com/api-keys
# Verifica tu dominio en https://resend.com/domains para enviar desde tu dominio
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=GymCoach <noreply@tudominio.com>

# URL base de la app (para enlaces en correos y recuperacion de contraseña)
# En Vercel se infiere automaticamente. En local usa http://localhost:3000
# IMPORTANTE: Añade en Supabase Dashboard > Auth > URL Configuration:
# - Site URL: tu URL de produccion
# - Redirect URLs: http://localhost:3000/auth/callback, https://tu-app.vercel.app/auth/callback
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# Opcional: zona horaria para cálculos de logros (por defecto la del servidor). Útil en tests locales.
# ACHIEVEMENTS_EARLY_TZ=America/Argentina/Buenos_Aires
# NEXT_PUBLIC_ACHIEVEMENTS_EARLY_TZ=America/Argentina/Buenos_Aires
